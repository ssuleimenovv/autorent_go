# Chat Service Configuration

# MongoDB
MongoDB__ConnectionString=mongodb://mongo:27017
MongoDB__DatabaseName=chat_db

# Internal API Keys
InternalAuth__ApiKey=local-chat-service-key

# File Service
FileService__BaseUrl=http://file-service:8080
FileService__InternalApiKey=local-file-service-key

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
LOG_LEVEL=INFO

# WebSocket Configuration
WebSocket__ReadBufferSize=1024
WebSocket__WriteBufferSize=1024

# Environment
ENVIRONMENT=Development
