# Image Service Configuration

# Google Cloud Storage
GCS__ProjectID=autorent-gcs
GCS__BucketName=autorent-images
GCS__CredentialsPath=/secrets/gcs-credentials.json

# Internal API Keys
InternalAuth__ApiKey=local-image-service-key

# Identity Service
Identity__BaseUrl=http://identity-service:8080

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
LOG_LEVEL=INFO

# Environment
ENVIRONMENT=Development
