# Identity Service Configuration

# Database
ConnectionStrings__DbConnection=postgres://postgres:postgres@identity-db:5432/postgres_db?sslmode=disable

# JWT Configuration
Jwt__PrivateKeyPath=/secrets/identity-private-key.pem
Jwt__PublicKeyPath=/secrets/identity-public-key.pem
Jwt__ExpiresInMinutes=15
Jwt__RefreshExpiresInDays=7

# Internal API Key
InternalAuth__ApiKey=local-identity-service-key

# RabbitMQ
RabbitMq__HostName=rabbitmq
RabbitMq__Port=5672
RabbitMq__UserName=autorent
RabbitMq__Password=autorent
RabbitMq__ExchangeName=autorent.events

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_SERVICE_NAME=identity-service
LOG_LEVEL=INFO
LOG_PATH=/tmp/autorent/identity-service

# Environment
ENVIRONMENT=Development
