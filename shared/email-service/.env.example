# Email Service Configuration

# SMTP
Smtp__Host=smtp.gmail.com
Smtp__Port=587
Smtp__Username=your-email@gmail.com
Smtp__Password=your-app-password
Smtp__FromAddress=noreply@autorent.com

# RabbitMQ
RabbitMq__HostName=rabbitmq
RabbitMq__Port=5672
RabbitMq__UserName=autorent
RabbitMq__Password=autorent
RabbitMq__ExchangeName=autorent.events
RabbitMq__QueueName=email-service-queue

# Internal API Key
InternalAuth__ApiKey=local-email-service-key

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
LOG_LEVEL=INFO

# Environment
ENVIRONMENT=Development
