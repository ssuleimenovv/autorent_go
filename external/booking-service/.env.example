# Booking Service Configuration

# Database
ConnectionStrings__DbConnection=postgres://postgres:postgres@booking-db:5432/booking_db?sslmode=disable

# Internal API Keys
InternalAuth__ApiKey=local-booking-service-key

# Service URLs
CarService__BaseUrl=http://car-service:8080
PaymentService__BaseUrl=http://payment-service:8080
DamageEval__BaseUrl=http://damage-eval-service:8080
TicketService__BaseUrl=http://ticket-service:8080

# RabbitMQ
RabbitMq__HostName=rabbitmq
RabbitMq__Port=5672
RabbitMq__UserName=autorent
RabbitMq__Password=autorent
RabbitMq__ExchangeName=autorent.events

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
LOG_LEVEL=INFO

# Environment
ENVIRONMENT=Development
