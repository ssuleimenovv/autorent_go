# Car Service Configuration

# Database
ConnectionStrings__DbConnection=postgres://postgres:postgres@car-db:5432/car_db?sslmode=disable

# Internal API Keys
InternalAuth__ApiKey=local-car-service-key

# Identity Service
Identity__BaseUrl=http://identity-service:8080

# Image Service
Image__BaseUrl=http://image-service:8080

# RabbitMQ
RabbitMq__HostName=rabbitmq
RabbitMq__Port=5672
RabbitMq__UserName=autorent
RabbitMq__Password=autorent
RabbitMq__ExchangeName=autorent.events

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
LOG_LEVEL=INFO

# Environment
ENVIRONMENT=Development
