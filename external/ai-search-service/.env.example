# AI Search Service Configuration

# Database
ConnectionStrings__DbConnection=postgres://postgres:postgres@ai-search-db:5432/ai_search_db?sslmode=disable

# Redis
Redis__Host=ai-search-redis
Redis__Port=6379

# Ollama
Ollama__BaseUrl=http://ollama:11434

# Internal API Keys
InternalAuth__ApiKey=local-ai-search-service-key

# Service URLs
CarService__BaseUrl=http://car-service:8080
PartnerService__BaseUrl=http://partner-service:8080

# RabbitMQ
RabbitMq__HostName=rabbitmq
RabbitMq__Port=5672
RabbitMq__UserName=autorent
RabbitMq__Password=autorent
RabbitMq__ExchangeName=autorent.events
RabbitMq__QueueName=ai-search-queue

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
LOG_LEVEL=INFO

# Environment
ENVIRONMENT=Development
