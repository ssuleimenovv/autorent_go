# File Service Configuration

# Google Cloud Storage
GCS__ProjectID=autorent-gcs
GCS__BucketName=autorent-files
GCS__CredentialsPath=/secrets/gcs-credentials.json

# Internal API Keys
InternalAuth__ApiKey=local-file-service-key

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
LOG_LEVEL=INFO

# Environment
ENVIRONMENT=Development
