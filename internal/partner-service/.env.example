# Partner Service Configuration

# Database
ConnectionStrings__DbConnection=postgres://postgres:postgres@partner-db:5432/partner_db?sslmode=disable

# Internal API Keys
InternalAuth__ApiKey=local-partner-service-key

# Service URLs
FileService__BaseUrl=http://file-service:8080
FileService__InternalApiKey=local-file-service-key
PaymentService__BaseUrl=http://payment-service:8080
BookingService__BaseUrl=http://booking-service:8080

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
LOG_LEVEL=INFO

# Environment
ENVIRONMENT=Development
