# Car Market Value Service Configuration

# Database (optional, for caching)
ConnectionStrings__DbConnection=postgres://postgres:postgres@market-value-db:5432/market_value_db?sslmode=disable

# Kolesa.kz API
Kolesa__BaseUrl=https://kolesa.kz/api
Kolesa__ApiKey=your-api-key

# Internal API Keys
InternalAuth__ApiKey=local-market-value-service-key

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
LOG_LEVEL=INFO

# Environment
ENVIRONMENT=Development
