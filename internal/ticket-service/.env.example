# Ticket Service Configuration

# Database
ConnectionStrings__DbConnection=postgres://postgres:postgres@ticket-db:5432/ticket_db?sslmode=disable

# Internal API Keys
InternalAuth__ApiKey=local-ticket-service-key

# Service URLs
FileService__BaseUrl=http://file-service:8080
FileService__InternalApiKey=local-file-service-key
IdentityService__BaseUrl=http://identity-service:8080
IdentityService__InternalApiKey=local-identity-service-key
ClientService__BaseUrl=http://client-service:8080
ClientService__InternalApiKey=local-client-service-key
PartnerService__BaseUrl=http://partner-service:8080
PartnerService__InternalApiKey=local-partner-service-key
CarService__BaseUrl=http://car-service:8080
CarService__InternalApiKey=local-car-service-key
ImageService__BaseUrl=http://image-service:8080

# RabbitMQ
RabbitMq__HostName=rabbitmq
RabbitMq__Port=5672
RabbitMq__UserName=autorent
RabbitMq__Password=autorent
RabbitMq__ExchangeName=autorent.events

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
LOG_LEVEL=INFO

# Environment
ENVIRONMENT=Development
